10 PRINT "** IEC LARGE FILE TEST **"
20 OPEN 1,8,2,"BIGDATA"
30 GET#1,A$:GET#1,A$
40 S=0:N=0
50 GET#1,A$
60 B=ASC(A$+CHR$(0))
70 S=S+B:N=N+1
80 IF (ST AND 64)=0 THEN GOTO 50
90 CLOSE 1
100 PRINT "BYTES:";N
110 PRINT "SUM:";S
120 IF N=2048 AND S=261120 THEN PRINT "PASS - DATA OK":END
130 PRINT "FAIL"
140 IF N<>2048 THEN PRINT "BYTES:";N;"NEED 2048"
150 IF S<>261120 THEN PRINT "SUM:";S;"NEED 261120"
160 END
